{% for course in site.data.courses %}{% if course.number == include.number %}<a href="{% if course.number < 5000 %}{{site.url}}/courses/undergrad/#{{course.number}}{%else%}{{site.url}}/courses/graduate/#{{course.number}}{%endif%}" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-trigger="click hover focus" data-bs-html="true" title='{{course.name}}' class="my-tooltip" style="white-space:nowrap">MATH {{include.number}}</a>{%endif%}{%endfor%}
